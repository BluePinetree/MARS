# ============================================================
# AutoGen 자율 연구 시스템 - 환경 변수 설정
# ============================================================
# 이 파일을 .env로 복사한 후, 실제 API 키를 입력하세요.
# cp .env.example .env
#
# 사용하지 않는 프로바이더의 키는 비워두어도 됩니다.
# 단, config.yaml에서 해당 프로바이더를 에이전트에 매핑한 경우
# 반드시 해당 키를 설정해야 합니다.
# ============================================================

# --- OpenAI ---
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# --- Google (Gemini) ---
GOOGLE_API_KEY=your-google-api-key-here

# --- RabbitMQ (선택, 비동기 모드 사용 시) ---
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
