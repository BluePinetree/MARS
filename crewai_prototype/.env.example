# ============================================================
# MARS — CrewAI Backend Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.
#   cp .env.example .env
#
# At minimum, one of OPENAI_API_KEY or ANTHROPIC_API_KEY is required.
# Unused providers can be left empty.
# ============================================================

# --- LLM API Keys ---

# OpenAI (gpt-4o, gpt-4o-mini, ...)
OPENAI_API_KEY=sk-...

# Anthropic (claude-3-5-sonnet, claude-3-opus, ...)
ANTHROPIC_API_KEY=sk-ant-...

# Google (gemini-2.5-flash, gemini-2.5-pro, ...)
GOOGLE_API_KEY=AIza...

# --- Optional Tool Keys ---

# E2B Sandbox (sandboxed code execution — not required for local runs)
# E2B_API_KEY=e2b_...

# MLflow Tracking Server (defaults to http://localhost:5000 if unset)
# MLFLOW_TRACKING_URI=http://localhost:5000

# --- Pipeline Tuning (optional, defaults shown) ---

# Maximum wall-clock seconds for a single experiment script run
# EXPERIMENT_TIMEOUT_SECS=1800

# Maximum seconds to wait for user approval at the plan gate
# RESEARCH_PIPELINE_APPROVAL_TIMEOUT_SECS=3600

# Maximum seconds to wait for user guidance at a repair gate
# USER_GUIDANCE_TIMEOUT_SECS=7200

# Maximum Phase 2 coding repair attempts before escalating to user
# MAX_REPAIR_ATTEMPTS=5

# Maximum Phase 3 execution repair attempts before escalating to user
# MAX_EXEC_REPAIR_ATTEMPTS=3
